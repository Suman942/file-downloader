<?xml version="1.0" encoding="utf-8"?>
<layout>
    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainActivity">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Download 1 UI group -->
            <LinearLayout
                android:id="@+id/downloadGroup1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/textViewTitle1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Download 1"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <!-- Progress & Status vertically stacked -->
                <ProgressBar
                    android:id="@+id/progressBar1"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="0" />

                <TextView
                    android:id="@+id/textViewProgress1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress: 0%"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/textViewStatus1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: Idle"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp" />

                <!-- Buttons arranged horizontally -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/downloadBtn1"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Download" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/pauseBtn1"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Pause" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/resumeBtn1"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Resume" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/cancelBtn1"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Cancel" />
                </LinearLayout>

            </LinearLayout>

            <!-- Download 2 UI group -->
            <LinearLayout
                android:id="@+id/downloadGroup2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/textViewTitle2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Download 2"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <!-- Progress & Status vertically stacked -->
                <ProgressBar
                    android:id="@+id/progressBar2"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="0" />

                <TextView
                    android:id="@+id/textViewProgress2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress: 0%"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/textViewStatus2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: Idle"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp" />

                <!-- Buttons arranged horizontally -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/downloadBtn2"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Download" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/pauseBtn2"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Pause" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/resumeBtn2"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Resume" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/cancelBtn2"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Cancel" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</layout>
